// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: crops
// Document ID: auto-generated
// Fields:
//   - name: string (required, 1-100 chars)
//   - type: string (required, 1-50 chars)
//   - minPh: number (required, 0-14)
//   - maxPh: number (required, 0-14)
//   - waterRequirement: string (optional, enum: Low, Medium, High)
//   - growingSeason: string (optional, enum: Kharif, Rabi, Zaid)
//   - avgYieldPerAcre: number (optional, positive)
//   - avgCostPerAcre: number (optional, positive)
//
// Collection: soil_analyses
// Document ID: auto-generated
// Fields:
//   - userId: string (required, matches auth.uid)
//   - ph: number (required, 0-14)
//   - nitrogen: number (optional, positive)
//   - phosphorus: number (optional, positive)
//   - potassium: number (optional, positive)
//   - moisture: number (optional, 0-100)
//   - timestamp: timestamp (required, server-generated)
//
// Collection: market_prices
// Document ID: auto-generated
// Fields:
//   - cropName: string (required, 1-100 chars)
//   - pricePerKg: number (required, positive)
//   - region: string (optional, 1-100 chars)
//   - date: string (required, YYYY-MM-DD format)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "71762333022@cit.edu.in" && request.auth.token.email_verified == true);
    }

    function hasOnlyAllowedFields(allowedFields) {
      return request.resource.data.keys().hasOnly(allowedFields);
    }

    function hasRequiredFields(requiredFields) {
      return request.resource.data.keys().hasAll(requiredFields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidCrop(data) {
      return hasRequiredFields(['name', 'type', 'minPh', 'maxPh']) &&
             hasOnlyAllowedFields(['name', 'type', 'minPh', 'maxPh', 'waterRequirement', 'growingSeason', 'avgYieldPerAcre', 'avgCostPerAcre']) &&
             data.name is string && data.name.size() >= 1 && data.name.size() <= 100 &&
             data.type is string && data.type.size() >= 1 && data.type.size() <= 50 &&
             data.minPh is number && data.minPh >= 0 && data.minPh <= 14 &&
             data.maxPh is number && data.maxPh >= 0 && data.maxPh <= 14 &&
             (!('waterRequirement' in data) || (data.waterRequirement in ['Low', 'Medium', 'High'])) &&
             (!('growingSeason' in data) || (data.growingSeason in ['Kharif', 'Rabi', 'Zaid'])) &&
             (!('avgYieldPerAcre' in data) || (data.avgYieldPerAcre is number && data.avgYieldPerAcre >= 0)) &&
             (!('avgCostPerAcre' in data) || (data.avgCostPerAcre is number && data.avgCostPerAcre >= 0));
    }

    function isValidSoilAnalysis(data) {
      return hasRequiredFields(['userId', 'ph', 'timestamp']) &&
             hasOnlyAllowedFields(['userId', 'ph', 'nitrogen', 'phosphorus', 'potassium', 'moisture', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.ph is number && data.ph >= 0 && data.ph <= 14 &&
             data.timestamp == request.time &&
             (!('nitrogen' in data) || (data.nitrogen is number && data.nitrogen >= 0)) &&
             (!('phosphorus' in data) || (data.phosphorus is number && data.phosphorus >= 0)) &&
             (!('potassium' in data) || (data.potassium is number && data.potassium >= 0)) &&
             (!('moisture' in data) || (data.moisture is number && data.moisture >= 0 && data.moisture <= 100));
    }

    function isValidMarketPrice(data) {
      return hasRequiredFields(['cropName', 'pricePerKg', 'date']) &&
             hasOnlyAllowedFields(['cropName', 'pricePerKg', 'region', 'date']) &&
             data.cropName is string && data.cropName.size() >= 1 && data.cropName.size() <= 100 &&
             data.pricePerKg is number && data.pricePerKg >= 0 &&
             data.date is string && data.date.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
             (!('region' in data) || (data.region is string && data.region.size() <= 100));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Crops: Publicly readable, Admin writable
    match /crops/{cropId} {
      allow read: if true;
      allow create: if isAdmin() && isValidCrop(request.resource.data);
      allow update: if isAdmin() && isValidCrop(request.resource.data);
      allow delete: if isAdmin();
    }

    // Soil Analyses: Owner only
    match /soil_analyses/{analysisId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuthenticated() && isValidSoilAnalysis(request.resource.data);
      allow update: if isOwner(resource.data.userId) && isValidSoilAnalysis(request.resource.data) && 
                      request.resource.data.userId == resource.data.userId &&
                      request.resource.data.timestamp == resource.data.timestamp;
      allow delete: if isOwner(resource.data.userId);
    }

    // Market Prices: Publicly readable, Admin writable
    match /market_prices/{priceId} {
      allow read: if true;
      allow create: if isAdmin() && isValidMarketPrice(request.resource.data);
      allow update: if isAdmin() && isValidMarketPrice(request.resource.data);
      allow delete: if isAdmin();
    }
    
    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
